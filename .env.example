# ============================================================
# Numb タスク管理システム 環境変数テンプレート
# このファイルをコピーして .env を作成してください
# cp .env.example .env
# ============================================================

# --- LINE API 設定 ---
# LINE Developers Console から取得
# https://developers.line.biz/console/
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# LINE グループ ID（グループに Bot を招待後、Webhook ログから取得）
LINE_GROUP_ID=your_line_group_id_here

# --- Gemini API 設定 ---
# Google AI Studio から取得
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Google Sheets 設定 ---
# Google Cloud Console でスプレッドシートの ID を確認
# URL の /d/ と /edit の間の文字列
GOOGLE_SHEETS_ID=your_google_sheets_id_here

# サービスアカウントの JSON キーファイルのパス
# Google Cloud Console > IAM と管理 > サービスアカウント で作成
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json

# --- Flask 設定 ---
# 本番環境では必ず変更してください
FLASK_SECRET_KEY=your_secret_key_here
FLASK_DEBUG=False
FLASK_PORT=5000

# --- タイムゾーン設定 ---
TIMEZONE=Asia/Tokyo

# --- スケジューラー設定 ---
# 朝の通知時刻（HH:MM 形式）
MORNING_NOTIFICATION_HOUR=8
MORNING_NOTIFICATION_MINUTE=0
